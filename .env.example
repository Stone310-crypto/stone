# ─────────────────────────────────────────────────────────────────────────────
#  Stone Node — .env Konfiguration
#  Kopiere diese Datei nach .env und trage deine Werte ein.
#  Danach: python stone_init.py  → dann: cargo run --bin stone-master
# ─────────────────────────────────────────────────────────────────────────────

# ── Pflichtfelder ─────────────────────────────────────────────────────────────

# URL des forge-Nomad Servers (ohne abschließenden /)
NOMAD_URL=https://www.unrooted.dev

# Gemeinsames Geheimnis zwischen Node und Server (frei wählbar, aber sicher!)
# Muss identisch mit NODE_SECRET auf dem forge-Nomad Server sein.
NODE_SECRET=setze-hier-ein-sicheres-passwort

# ── Node-Identität ────────────────────────────────────────────────────────────

# Anzeigename dieser Node im Netzwerk
STONE_NODE_ID=mein-node-name

# Öffentlich erreichbare URL dieser Node (für andere Nodes im Cluster)
# Leer lassen wenn die Node nicht von außen erreichbar sein soll.
STONE_NODE_URL=http://meine-ip-oder-domain:8080

# ── Ports ─────────────────────────────────────────────────────────────────────

# HTTP-API Port (Standard: 8080)
STONE_HTTP_PORT=8080

# P2P-Netzwerk Port für libp2p (Standard: 7654)
# Nur relevant wenn mehrere Nodes im selben Netzwerk laufen.
STONE_P2P_PORT=7654

# ── Automatisch gesetzt (von stone_init.py) ───────────────────────────────────
# Diese Felder NICHT manuell setzen — werden durch stone_init.py befüllt.

# STONE_CLUSTER_API_KEY=sk_...   ← wird von stone_init.py gesetzt
# STONE_BOOTSTRAP_AT=...         ← Timestamp des letzten Bootstraps

# ── Optional ──────────────────────────────────────────────────────────────────

# P2P deaktivieren (nur HTTP-API, kein mDNS/Kademlia)
# STONE_P2P_DISABLED=1

# TLS für die HTTP-API aktivieren (Produktion)
# STONE_TLS_CERT=/pfad/zum/cert.pem
# STONE_TLS_KEY=/pfad/zum/key.pem

# ── Cloudflare Tunnel (öffentlicher Zugang ohne Port-Forwarding) ───────────────

# "quick"  → Quick-Tunnel (kein Account, URL ändert sich bei jedem Start)
# "named"  → Named-Tunnel (feste URL, eigene Domain)
# leer lassen → Tunnel deaktiviert
STONE_TUNNEL=quick

# Nur bei Named-Tunnel: Token aus dem Cloudflare Dashboard
# STONE_TUNNEL_TOKEN=eyJhIjoiN...

# Nur bei Named-Tunnel: eigene Subdomain (z.B. node1.unrooted.dev)
# STONE_TUNNEL_DOMAIN=node1.unrooted.dev

# ── Dashboard v2 (Custom Node Dashboards) ───────────────────────────────────

# Aktiviert v2 Dashboard-Contracts (Capabilities, Scopes, Manifest-Validation)
# STONE_DASHBOARD_V2_ENABLED=1

# Erlaubt Remote Dashboard Widgets (falls 0: nur lokale/gebundene Widgets)
# STONE_DASHBOARD_ALLOW_REMOTE_WIDGETS=0

# Kommagetrennte Allowlist für Widget-Origins (z.B. https://dash.example.com)
# STONE_DASHBOARD_ALLOWED_WIDGET_ORIGINS=

# Optionale Zusatz-Scopes fuer nicht-admin Dashboard-Nutzer (CSV)
# Beispiel: chat:read,mining:read
# STONE_DASHBOARD_EXTRA_SCOPES=

# Erzwingt app_id bei Dashboard-v2 Requests (per-App Scope-Modell)
# STONE_DASHBOARD_REQUIRE_APP_ID=1

# Secret für Dashboard-App-Tokens (Bearer sd2....). Falls leer: Admin-Key als Fallback.
# STONE_DASHBOARD_TOKEN_SECRET=

# Vorheriges Secret für Rolling-Rotation (nur Verify, nicht Sign)
# STONE_DASHBOARD_TOKEN_PREVIOUS_SECRET=

# Zusätzliche Verify-Secrets als CSV (optional, z.B. bei mehrstufigen Rotationen)
# STONE_DASHBOARD_TOKEN_VERIFY_SECRETS=

# Standardlaufzeit für neu ausgestellte Dashboard-App-Tokens (Sekunden)
# STONE_DASHBOARD_TOKEN_TTL_SECS=86400

# ── Discord OAuth2 Login ───────────────────────────────────────────────────────

# Discord Developer Portal → Applications → deine App → OAuth2
# Benötigt für POST /api/v1/auth/discord
DISCORD_CLIENT_ID=1504220990484385883
DISCORD_CLIENT_SECRET=U8qYqrHUwQpxzm4QH3cMc_O5MYuqDjwq
