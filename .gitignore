# ─── Build-Artefakte ─────────────────────────────────────────────────────────
/target/

# ─── Secrets & API-Keys (NIE committen) ──────────────────────────────────────
.env
*.env.local
.env
token.bin
/stone_data/shared/

# Firebase / Google Cloud Service-Account-Keys (NIE committen)
*firebase*adminsdk*.json
*-sa.json
firebase-sa.json
service-account*.json
gcp-*.json

# Node-Config enthält api_key + password_hash → nie versionieren.
# Template liegt unter node_config.example.json.
node_config.json
node_config.*.json
!node_config.example.json

# ─── Laufzeit-Daten (generiert vom Node, nicht versioniert) ──────────────────
/stone_data/
/stone_data_mainnet/

# ─── TLS-Zertifikate & PKI ───────────────────────────────────────────────────
# Produzierte Certs gehören nicht ins Repo — nur Root-CA für dev kann committed werden
tls/
*.crt
*.key
*.pem
*.srl
ca/

# ─── macOS System-Dateien ─────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ─── Editoren & IDEs ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Backups & temporäre Dateien ─────────────────────────────────────────────
*.bak
*.tmp
*.orig
flycheck*/

# ─── Log-Dateien ─────────────────────────────────────────────────────────────
*.log
